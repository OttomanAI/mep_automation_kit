    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import FilteredWorksetCollector, WorksetKind\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nworksets = FilteredWorksetCollector(doc).OfKind(WorksetKind.UserWorkset).ToWorksets()\r\n\r\nsearch = IN[0]\r\nfor w in worksets:\r\n    if search in w.Name:\r\n        OUT = w.Id.IntegerValue\r\n        break\r\nelse:\r\n    OUT = \"Not found: \" + search",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "6001afc7b7eb41ec825c160838e6eef8",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "6584f902c27449408dc334ac4c8ab3df",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "bcf2a398341c4177a48d02b14470ff4a",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    }
  ],
